---
pagination:
  data: catalog.models
  alias: model
  size: 1
permalink: 'catalog/models/{{model.id | slugify}}/'
eleventyExcludeFromCollections: true
---
<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="refresh" content="0; url=/catalog#{{ model.id }}">
    <link rel="canonical" href="/catalog#{{ model.id }}">
    <title>{{ model.name }} – dynamical.org</title>
  </head>
  <body>
    <p>Redirecting to <a href="/catalog#{{ model.id }}">catalog</a>…</p>
  </body>
</html>
