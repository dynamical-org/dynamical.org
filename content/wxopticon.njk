---
layout: base
title: status
permalink: /status/
---

<div class="content">
  <main id="wx-app">
    <div class="status-ribbon" data-slot="ribbon" hidden>
      <span>Viewing history: <strong data-slot="ribbon-ts">—</strong></span>
      <button type="button" data-slot="ribbon-return">← return to live</button>
    </div>
    <div data-slot="banners"></div>

    <div class="status-controls">
      <select id="wx-time-toggle">
        <option value="utc">Coordinated Universal Time (UTC)</option>
        <option value="local">Local time</option>
      </select>
      <button
        type="button"
        id="wx-history-toggle"
        aria-expanded="false"
        aria-controls="wx-history-panel"
        aria-label="Toggle history scrub"
        title="Toggle history scrub"
      >📅</button>
    </div>
    <div id="wx-history-panel" hidden>
      <span class="status-history-label" data-slot="scrub-label" aria-hidden="true">—</span>
      <input
        type="range"
        id="wx-history-range"
        min="0"
        max="0"
        value="0"
        step="1"
        aria-label="Wxopticon history scrub"
        aria-valuetext="live"
        disabled
      >
      <p data-slot="scrub-error" hidden></p>
    </div>

    {% for product in wxopticon.products %}
    <section class="status-row" data-product-id="{{ product.id }}">
      <div>
        <strong>{{ product.label }}</strong>
        <div style="font-size:1.2rem;">
          <div>{{ product.source }}</div>
          <div>{{ product.cadence_hours }}h cadence</div>
        </div>
      </div>
      <div class="status-grid" data-slot="grid">
        {% for _ in range(0, product.recent_init_count) %}
        <div class="status-bar" data-skeleton>
          <div class="status-bar-track"></div>
          <div class="status-bar-label"></div>
        </div>
        {% endfor %}
      </div>
      <div class="status-stats">
        <div class="status-eta" data-slot="eta">—</div>
        <div>---</div>
        <div data-slot="latency">p50 -h -m<br>p95 -h -m<br>p99 -h -m</div>
      </div>
    </section>
    {% endfor %}

    <footer class="status-footer">
      <div>Updated <span data-slot="generated-at">—</span></div>
      <div>{{ wxopticon.window_days }}-day rolling window · polls every 15s</div>
    </footer>
  </main>
</div>

<script src="/wxopticon.js" defer></script>
