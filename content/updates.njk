---
layout: base.njk
title: updates
redirect_from: [/follow, /follow.html]
---

<div id="newsletter" class="content centered" style="margin-bottom: 4rem;">
  <form
    action="https://buttondown.email/api/emails/embed-subscribe/dynamical"
    method="post"
    target="popupwindow"
    onsubmit="window.open('https://buttondown.email/dynamical', 'popupwindow')"
    class="embeddable-buttondown-form"
  >
    <label for="email">Email</label>
    <input type="email" name="email" placeholder="marshall@dynamical.org" style="width: 300px;"/>
    <br />
    <input type="checkbox" name="tag" id="tester" value="tester" />
    <label for="tag">I would like to test new datasets and libraries</label>
    <br />

    <input type="hidden" value="1" name="embed" />
    <input type="submit" value="Subscribe to updates" />
  </form>
  <p>
    <a href="https://www.linkedin.com/company/dynamical-org">LinkedIn</a> ·
    <a href="https://youtube.com/@dynamical-org">YouTube</a>
  </p>
</div>

<div class="content">
{%- for post in collections.updates | reverse -%}
  {%- if post.data.kind == "note" -%}
  {# Lab notes are too long to inline — link out to their own page. #}
  <a class="note-card" href="{{ post.url }}">
    <div class="note-meta">
      <span class="status-pill status-pill--other">{{ post.data.status or "Lab note" }}</span>
      <em>{{ post.page.date | readableDate }}</em>
    </div>
    <h2>{{ post.data.title }}</h2>
    {%- if post.data.summary %}<p class="note-summary">{{ post.data.summary }}</p>{% endif -%}
    <div class="note-card-footer">
      {%- if post.data.authors -%}
      <span class="note-byline">
        {%- for author in post.data.authors -%}{{ author.name or author }}{% if not loop.last %}, {% endif %}{%- endfor -%}
      </span>
      {%- endif -%}
      <span class="note-read">Read →</span>
    </div>
  </a>
  {%- else -%}
  <article>
    <div class="note-meta">
      <span class="status-pill status-pill--other">Update</span>
      <em>{{ post.page.date | readableDate }}</em>
    </div>
    <h2>{{ post.data.title }}</h2>
    {{ post.content | safe }}
  </article>
  {%- endif -%}
{%- endfor -%}
</div>
