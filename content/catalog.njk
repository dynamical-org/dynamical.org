---
layout: base.njk
title: catalog
socialTitle: Open weather & climate data catalog
description: Free, live-updating, cloud-optimized weather datasets from NOAA, ECMWF, and DWD — analysis-ready through Icechunk, Xarray, and STAC.
keywords: "cloud-optimized weather data, weather data catalog, analysis-ready weather data, weather forecast data, reanalysis data, GRIB alternative, Zarr, Icechunk, Xarray, NOAA GFS, GEFS, HRRR, ECMWF IFS, DWD ICON, open weather data"
---

{% from "tag-icon.njk" import tagIcon %}

<style>
  /* Catalog grouped by model: each model heads a short .index-list of its
     dataset variants (materialized / virtual / both). Uses the shared
     .index-list skeleton plus these row styles (title flex + full-width specs).
     The scroll-spy TOC rail (lib/markdown-toc.js, tocCSS/tocJS) navigates the
     model-group <h2>s. */
  .model-group {
    margin-top: 2.5rem;
  }
  .model-group > strong {
    display: block;
    margin-bottom: 0.2rem;
    scroll-margin-top: 2rem;
  }

  .cat-name {
    font-weight: 700;
    text-decoration: underline;
    color: var(--link-color);
  }

  /* Title row: title on the left, id pushed to the right (hidden on narrow
     screens). */
  .cat-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.6rem;
  }
  .cat-id {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--muted-text);
  }
  @media (max-width: 640px) {
    .cat-id {
      display: none;
    }
  }

  /* Benefit tags: inline icon + label list. Icons inherit currentColor. */
  .cat-tags {
    margin-top: 0.3rem;
    color: var(--muted-text);
  }
  .cat-tags svg {
    margin-right: 0.4em;
  }

  .cat-meta {
    margin-top: 0.3rem;
    font-variant-numeric: tabular-nums;
  }
  /* Keep each attribute intact; let the row wrap only at the · delimiters. */
  .cat-meta span {
    white-space: nowrap;
  }
</style>

{%- set shownModels = [] -%}
{%- for model in catalog.models -%}
  {%- set live = model.datasets | selectattr("status", "!=", "deprecated") | list -%}
  {%- if live.length -%}{%- set _ = shownModels.push({ model: model, datasets: live }) -%}{%- endif -%}
{%- endfor -%}

<div class="content md-toc-content">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
    <h1>Catalog</h1>
    <div style="margin-left: auto; display: flex; gap: 1rem; align-items: center;">
      <span><a href="https://stac.dynamical.org/catalog.json">STAC</a> (<a href="https://radiantearth.github.io/stac-browser/#/external/stac.dynamical.org/catalog.json">browse</a>)</span>
    </div>
  </div>

  <div class="md-toc-rail">
    <nav class="md-toc" aria-label="Models">
      <ul class="toc-tree">
        {% for item in shownModels %}
        <li class="toc-h2"><a href="#{{ item.model.id | slugify }}">{{ item.model.name }}</a></li>
        {% endfor %}
        <li class="toc-h2"><a href="#experimental">Experimental</a></li>
      </ul>
    </nav>
  </div>

  {% macro meta(ds) %}
    {%- set vars = "all variables" if ds.optimization == "space" else (ds.variable_count | string) + " variables" -%}
    {%- if ds.forecast_domain -%}
      {%- set fields = [ds.spatial_domain | replace("Continental United States", "CONUS"), vars, ds.spatial_resolution | stripApprox | replace(" degrees", "°") | abbrevHours, ds.forecast_domain | replace("Forecast lead time ", "") | replace(" ahead", "") | abbrevHours, ds.time_resolution | replace("Forecasts initialized ", "") | abbrevHours] -%}
    {%- else -%}
      {%- set fields = [ds.spatial_domain | replace("Continental United States", "CONUS"), vars, ds.spatial_resolution | stripApprox | replace(" degrees", "°") | abbrevHours, ds.time_domain | dateOnly, ds.time_resolution | hourlyStep] -%}
    {%- endif -%}
    {%- for f in fields %}{% if not loop.first %} {% endif %}<span>{% if not loop.first %}· {% endif %}{{ f }}</span>{% endfor -%}
  {% endmacro %}

  {% macro tags(ds) %}
    <div class="cat-tags">{% for t in ds.access_tags %}{{ tagIcon(t.icon) }}{{ t.label }}{{ " · " if not loop.last }}{% endfor %}</div>
  {% endmacro %}

  {% for item in shownModels %}
    <section class="model-group">
      <strong id="{{ item.model.id | slugify }}">{{ item.model.name }}</strong>
      <ul class="index-list">
      {% for ds in item.datasets %}
        <li>
        {% if ds.status == 'live' or ds.status == 'available' %}
          <a href="/catalog/{{ ds.id | slugify }}">
            <div class="cat-head"><span class="cat-name">{{ ds.title }}</span><span class="cat-id">{{ ds.id }}</span></div>
            {{ tags(ds) }}
            <div class="cat-meta">{{ meta(ds) }}</div>
          </a>
        {% else %}
          <div class="cat-head"><span class="cat-name">{{ ds.title }} ({{ ds.status }})</span><span class="cat-id">{{ ds.id }}</span></div>
          {{ tags(ds) }}
          <div class="cat-meta">{{ meta(ds) }}</div>
        {% endif %}
        </li>
      {% endfor %}
      </ul>
    </section>
  {% endfor %}

  <section class="model-group">
    <strong id="experimental">Experimental</strong>
    <ul class="index-list">
    <li>
      <a href="/catalog/asos-parquet">
        <div class="cat-head"><span class="cat-name">Global Airport Observations (ASOS/AWOS)</span></div>
        <div class="cat-meta">Historical and near-real-time METAR observations from ~2,500 stations. Updated hourly in GeoParquet.</div>
      </a>
    </li>
    </ul>
  </section>

  <hr style="margin: 6rem 0;" />
  <h2>Roadmap</h2>
  <p>To view work in progress and upcoming roadmap, check out the <a href="https://github.com/orgs/dynamical-org/projects/1">dynamical.org Github project</a>.</p>

</div>

<style>{{ tocCSS | safe }}</style>
<script>{{ tocJS | safe }}</script>
