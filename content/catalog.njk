---
layout: base.njk
title: catalog
---

<div class="content">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
    <h1>Catalog</h1>
    <div style="margin-left: auto; display: flex; gap: 1rem; align-items: center;">
      <a href="/catalog/llms">🤖</a>
    </div>
  </div>

  <div class="table-container">
    <table class="data catalog-table">
      <tr>
        <th>Model</th>
        <th></th>
        <th>Resolution</th>
        <th>Domain</th>
      </tr>
      {% for model in catalog.models %}
        {% set liveEntries = model.datasets | rejectWhere("status", "deprecated") %}
        {% for entry in liveEntries %}
          <tr{% if loop.last %} class="catalog-group-last"{% endif %}>
            {% if loop.first %}
              <td rowspan="{{ liveEntries | length }}" class="catalog-model-cell">
                <div style="display: flex; align-items: center;">
                  <span class="catalog-glyph">{{ model.glyph | safe }}</span>{{ model.name }}
                </div>
              </td>
            {% endif %}
            <td>
              {% if entry.status == 'live' or entry.status == 'available' %}
                <a href="/catalog/{{ entry.dataset_id | slugify }}">{{ entry.name | replace(model.name, '') | trim }}</a>
              {% else %}
                {{ entry.name | replace(model.name, '') | trim }} ({{ entry.status }})
              {% endif %}
            </td>
            <td class="catalog-resolution">{{ entry.spatial_resolution }}</td>
            <td>{{ entry.spatial_domain }}</td>
          </tr>
        {% endfor %}
      {% endfor %}
    </table>
  </div>

  <hr style="margin: 6rem 0;" />
  <h2>Roadmap</h2>
  <p>To view work in progress and upcoming roadmap, check out the <a href="https://github.com/orgs/dynamical-org/projects/1">dynamical.org Github project</a>.</p>

  <hr style="margin: 6rem 0;" />
  <h2>Experimental</h2>
  <div class="table-container">
    <table class="data catalog-table">
      <tr>
        <td><a href="/catalog/asos-parquet">Global Airport Observations (ASOS/AWOS)</a></td>
        <td>Historical and near-real-time METAR observations from ~2,500 stations. Updated hourly in GeoParquet.</td>
      </tr>
    </table>
  </div>

</div>
