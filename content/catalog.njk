---
layout: base.njk
title: catalog
---

<style>
  /* Catalog list (forecasts / analyses) — scoped to this page. */
  .cat-row {
    display: block;
    padding: 1.2rem 0;
    border-bottom: 1px dotted var(--border-muted-color);
  }
  /* The whole row is the click target; only the model name carries the link
     color + hover underline (the optimization tag stays quiet). */
  a.cat-row,
  a.cat-row:visited {
    color: inherit;
    text-decoration: none;
  }
  a.cat-row:focus-visible {
    outline: 2px solid var(--link-color);
    outline-offset: 2px;
  }
  .cat-name {
    font-weight: 700;
  }
  a.cat-row .cat-name {
    color: var(--link-color);
  }
  a.cat-row:hover .cat-name {
    text-decoration: underline;
  }
  .opt-tag {
    margin-left: 0.7rem;
    font-size: 1.05rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted-text-2);
  }
  .cat-meta {
    margin-top: 0.3rem;
    color: var(--muted-text);
    font-size: 1.25rem;
    font-variant-numeric: tabular-nums;
  }
</style>

<div class="content">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
    <h1>Catalog</h1>
    <div style="margin-left: auto; display: flex; gap: 1rem; align-items: center;">
      <span><a href="https://stac.dynamical.org/catalog.json">STAC</a> (<a href="https://radiantearth.github.io/stac-browser/#/external/stac.dynamical.org/catalog.json">browse</a>)</span>
    </div>
  </div>

  {% macro meta(entry, isForecast) %}
    {%- set vars = "all variables" if entry.optimization == "space" else (entry.variable_count | string) + " variables" -%}
    {%- if isForecast -%}
      {{ entry.spatial_domain | replace("Continental United States", "CONUS") }} · {{ vars }} · {{ entry.spatial_resolution | stripApprox | replace(" degrees", "°") }} · {{ entry.forecast_domain | replace("Forecast lead time ", "") | replace(" ahead", "") }} · {{ entry.time_resolution | replace("Forecasts initialized ", "") }}
    {%- else -%}
      {{ entry.spatial_domain | replace("Continental United States", "CONUS") }} · {{ vars }} · {{ entry.spatial_resolution | stripApprox | replace(" degrees", "°") }} · {{ entry.time_domain | dateOnly }} · {{ entry.time_resolution }}
    {%- endif -%}
  {% endmacro %}

  {% macro listSection(entries, isForecast) %}
    {% for entry in entries %}
      {%- set optTag %}<span class="opt-tag">{{ "space-optimized" if entry.optimization == "space" else "time-optimized" }}</span>{% endset -%}
      {% if entry.status == 'live' or entry.status == 'available' %}
        <a class="cat-row" href="/catalog/{{ entry.id | slugify }}">
          <span class="cat-name">{{ entry.model_name }}</span>{{ optTag | safe }}
          <div class="cat-meta">{{ meta(entry, isForecast) }}</div>
        </a>
      {% else %}
        <div class="cat-row">
          <span class="cat-name">{{ entry.model_name }} ({{ entry.status }})</span>{{ optTag | safe }}
          <div class="cat-meta">{{ meta(entry, isForecast) }}</div>
        </div>
      {% endif %}
    {% endfor %}
  {% endmacro %}

  <h2>Forecasts</h2>
  <p>Archives of past and present model runs, identified by initialization time and stepping forward across lead times.</p>
  {{ listSection(catalog.forecasts, true) }}

  <h2 style="margin-top: 4rem;">Analyses</h2>
  <p>Best-estimate archives of past weather, built by concatenating the earliest hours of each historical run into a continuous time series.</p>
  {{ listSection(catalog.analyses, false) }}

  <h2 style="margin-top: 4rem;">Experimental</h2>
  <a class="cat-row" href="/catalog/asos-parquet">
    <span class="cat-name">Global Airport Observations (ASOS/AWOS)</span>
    <div class="cat-meta">Historical and near-real-time METAR observations from ~2,500 stations. Updated hourly in GeoParquet.</div>
  </a>

  <hr style="margin: 6rem 0;" />
  <h2>Roadmap</h2>
  <p>To view work in progress and upcoming roadmap, check out the <a href="https://github.com/orgs/dynamical-org/projects/1">dynamical.org Github project</a>.</p>

</div>
