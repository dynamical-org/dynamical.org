---
layout: base.njk
title: catalog
---

<div class="content">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
    <h1>Catalog</h1>
    <div style="margin-left: auto; display: flex; gap: 1rem; align-items: center;">
      <span><a href="https://stac.dynamical.org/catalog.json">STAC</a> (<a href="https://radiantearth.github.io/stac-browser/#/external/stac.dynamical.org/catalog.json">browse</a>)</span>
    </div>
  </div>

  {% macro meta(entry, isForecast) %}
    {%- set vars = "complete" if entry.optimization == "space" else (entry.variable_count | string) + " variables" -%}
    {%- if isForecast -%}
      {{ entry.spatial_domain }} · {{ entry.spatial_resolution }} · {{ entry.time_resolution | replace("Forecasts initialized ", "") }} · {{ entry.forecast_domain | replace("Forecast lead time ", "") | replace(" ahead", "") }} · {{ vars }}
    {%- else -%}
      {{ entry.spatial_domain }} · {{ entry.spatial_resolution }} · {{ entry.time_resolution }} · {{ entry.time_domain }} · {{ vars }}
    {%- endif -%}
  {% endmacro %}

  {% macro listSection(entries, isForecast) %}
    <div class="cat-list">
      {% for entry in entries %}
        {%- set optTag %}<span class="opt-tag">{{ "space-optimized" if entry.optimization == "space" else "time-optimized" }}</span>{% endset -%}
        {% if entry.status == 'live' or entry.status == 'available' %}
          <a class="cat-row" href="/catalog/{{ entry.id | slugify }}">
            <div class="cat-row-head">{{ entry.model_name }}{{ optTag | safe }}</div>
            <div class="cat-meta">{{ meta(entry, isForecast) }}</div>
          </a>
        {% else %}
          <div class="cat-row cat-row--inactive">
            <div class="cat-row-head">{{ entry.model_name }} ({{ entry.status }}){{ optTag | safe }}</div>
            <div class="cat-meta">{{ meta(entry, isForecast) }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  {% endmacro %}

  <h2>Forecasts</h2>
  <p class="cat-intro">Archives of past and present model runs, identified by initialization time and stepping forward across lead times.</p>
  {{ listSection(catalog.forecasts, true) }}

  <h2 style="margin-top: 4rem;">Analyses</h2>
  <p class="cat-intro">Best-estimate archives of past weather, built by concatenating the earliest hours of each historical run into a continuous time series.</p>
  {{ listSection(catalog.analyses, false) }}

  <hr style="margin: 6rem 0;" />
  <h2>Roadmap</h2>
  <p>To view work in progress and upcoming roadmap, check out the <a href="https://github.com/orgs/dynamical-org/projects/1">dynamical.org Github project</a>.</p>

  <hr style="margin: 6rem 0;" />
  <h2>Experimental</h2>
  <div class="table-container">
    <table class="data catalog-table">
      <tr>
        <td><a href="/catalog/asos-parquet">Global Airport Observations (ASOS/AWOS)</a></td>
        <td>Historical and near-real-time METAR observations from ~2,500 stations. Updated hourly in GeoParquet.</td>
      </tr>
    </table>
  </div>

</div>
