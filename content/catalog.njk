---
layout: base.njk
title: catalog
---

<div class="content">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
    <h1>Catalog</h1>
    <div style="margin-left: auto; display: flex; gap: 1rem; align-items: center;">
      <span><a href="https://stac.dynamical.org/catalog.json">STAC</a> (<a href="https://radiantearth.github.io/stac-browser/#/external/stac.dynamical.org/catalog.json">browse</a>)</span>
    </div>
  </div>

  {% macro nameLink(entry) %}
    {%- if entry.status == 'live' or entry.status == 'available' -%}
      <a href="/catalog/{{ entry.id | slugify }}">{{ entry.model_name }}</a>
    {%- else -%}
      {{ entry.model_name }} ({{ entry.status }})
    {%- endif -%}
  {% endmacro %}

  {% macro badge(entry) %}
    <span class="opt-badge opt-badge--{{ entry.optimization }}">{{ "space-optimized" if entry.optimization == "space" else "time-optimized" }}</span>
  {% endmacro %}

  {% macro meta(entry, isForecast) %}
    {%- if isForecast -%}
      {{ entry.spatial_domain }} · {{ entry.spatial_resolution }} · {{ entry.time_resolution | replace("Forecasts initialized ", "") }} · {{ entry.forecast_domain | replace("Forecast lead time ", "") | replace(" ahead", "") }}
    {%- else -%}
      {{ entry.spatial_domain }} · {{ entry.spatial_resolution }} · {{ entry.time_resolution }} · {{ entry.time_domain }}
    {%- endif -%}
  {% endmacro %}

  {% macro listSection(entries, isForecast) %}
    <div class="cat-list">
      {% for entry in entries %}
        <div class="cat-row">
          <div class="cat-row-head">{{ nameLink(entry) }}{{ badge(entry) }}</div>
          <div class="cat-meta">{{ meta(entry, isForecast) }}</div>
          <div class="cat-desc">{{ entry.description }}</div>
        </div>
      {% endfor %}
    </div>
  {% endmacro %}

  {% macro cardSection(entries, isForecast) %}
    <div class="cat-cards">
      {% for entry in entries %}
        <div class="cat-card">
          <div class="cat-card-head">{{ nameLink(entry) }}{{ badge(entry) }}</div>
          <div class="cat-meta">{{ meta(entry, isForecast) }}</div>
          <div class="cat-desc">{{ entry.description }}</div>
          {% if entry.status == 'live' or entry.status == 'available' %}
            <a class="cat-go" href="/catalog/{{ entry.id | slugify }}">→ view dataset</a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endmacro %}

  {% set forecastsIntro = "Archives of past and present model runs, identified by initialization time and stepping forward across lead times." %}
  {% set analysesIntro = "Best-estimate archives of past weather, built by concatenating the earliest hours of each historical run into a continuous time series." %}

  <p class="cat-note"><em>Preview — two layout options below; pick one and I'll drop the other.</em></p>

  <hr style="margin: 2rem 0 3rem;" />
  <h2>Option A — list</h2>

  <h3>Forecasts</h3>
  <p class="cat-intro">{{ forecastsIntro }}</p>
  {{ listSection(catalog.forecasts, true) }}

  <h3 style="margin-top: 3rem;">Analyses</h3>
  <p class="cat-intro">{{ analysesIntro }}</p>
  {{ listSection(catalog.analyses, false) }}

  <hr style="margin: 6rem 0 3rem;" />
  <h2>Option B — cards</h2>

  <h3>Forecasts</h3>
  <p class="cat-intro">{{ forecastsIntro }}</p>
  {{ cardSection(catalog.forecasts, true) }}

  <h3 style="margin-top: 3rem;">Analyses</h3>
  <p class="cat-intro">{{ analysesIntro }}</p>
  {{ cardSection(catalog.analyses, false) }}

  <hr style="margin: 6rem 0;" />
  <h2>Roadmap</h2>
  <p>To view work in progress and upcoming roadmap, check out the <a href="https://github.com/orgs/dynamical-org/projects/1">dynamical.org Github project</a>.</p>

  <hr style="margin: 6rem 0;" />
  <h2>Experimental</h2>
  <div class="table-container">
    <table class="data catalog-table">
      <tr>
        <td><a href="/catalog/asos-parquet">Global Airport Observations (ASOS/AWOS)</a></td>
        <td>Historical and near-real-time METAR observations from ~2,500 stations. Updated hourly in GeoParquet.</td>
      </tr>
    </table>
  </div>

</div>
