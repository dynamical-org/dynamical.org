---
layout: base.njk
pagination:
  data: catalog.entries
  alias: entry
  size: 1
  addAllPagesToCollections: true
permalink: 'catalog/{{entry.id | slugify}}/'
eleventyComputed:
  title: '{{entry.title}}'
  description: '{{ entry.description_meta }}'
  socialTitle: '{{ entry.title }} — dynamical.org'
  socialImage: '{{ entry.thumbnail }}'
---

<style>
  .content.catalog-item {
    font-size: 1.4rem;
  }
  .metadata-comment {
    font-size: 80%;
  }
  .metadata-comment td {
    padding-top: 0;
  }
  .metadata-comment span {
    background-color: rgb(250, 250, 250);
    color: rgb(45, 45, 45);
  }
  .variable-group {
    margin-top: 1rem;
  }
  .variable-group > summary {
    cursor: pointer;
    font-size: 1.1em;
  }
  .variable-group > summary > strong {
    margin-left: 0.5em;
  }
  .variable-dimensions {
    white-space: nowrap;
  }
</style>
<script type="application/ld+json">{{ entry.jsonld | dump | safe }}</script>
{% macro variableTable(variables) %}
  <div class="table-container">
    <table class="data">
      <tr>
        <th/>
        <th class='right'>units</th>
        <th class='right variable-dimensions'>dimensions</th>
      </tr>
      {% for variable in variables %}
        <tr>
          <td>
            <strong>{{ variable.name }}</strong>{% if variable.short_name %} (<code>{{ variable.short_name }}</code>){% endif %}
            <p class="metadata-comment">{{ variable.long_name }}</p>
            {% if variable.comment %}
              <p class="metadata-comment">{{ variable.comment }}</p>
            {% endif %}
          </td>
          <td class='right'>{{ variable.units }}</td>
          <td class='right variable-dimensions'>{{ variable.dimension_names.join(' × ') }}</td>
        </tr>
        <tr class="metadata-comment">
          <td colspan="3">
            <span></span>
          </td>
        </tr>
      {% endfor %}
    </table>
  </div>
{% endmacro %}
<div class="content catalog-item">
  {%- set model = catalog.models | find('id', entry.model_id) %}
  <div>
    <a href="/catalog">Catalog</a>
    > {{ entry.title }}
  </div>
  <div style="margin: 3rem 0;">
    {% include "catalog-entry-status.njk" %}
    <h1>{{ entry.title }}</h1>
  </div>
  <table>
    <tr>
      <td>Spatial domain</td>
      <td>{{ entry.spatial_domain }}</td>
    </tr>
    <tr>
      <td>Spatial resolution</td>
      <td>{{ entry.spatial_resolution }}</td>
    </tr>
    <tr>
      <td>Time domain</td>
      <td>{{ entry.time_domain }}</td>
    </tr>
    <tr>
      <td>Time resolution</td>
      <td>{{ entry.time_resolution }}</td>
    </tr>
    {% if entry.forecast_domain %}
      <tr>
        <td>Forecast domain</td>
        <td>{{ entry.forecast_domain }}</td>
      </tr>
      <tr>
        <td>Forecast resolution</td>
        <td>{{ entry.forecast_resolution }}</td>
      </tr>
    {% endif %}
  </table>
  <p>
    <span><a href="https://stac.dynamical.org/{{ entry.id }}/collection.json">STAC</a> (<a href="https://radiantearth.github.io/stac-browser/#/external/stac.dynamical.org/{{ entry.id }}/collection.json">browse</a>)</span>
    {%- set validationReport = validationReports.entries | find('datasetId', entry.id) %}
    {% if validationReport %}
      · <a href="/catalog/{{ entry.id }}/validation/">validation report</a>
    {% elif entry.validation_report_href %}
      · <a href="{{ entry.validation_report_href }}">validation report</a>
    {% endif %}
  </p>
  {% if model.description %}
    <p style="text-wrap: balance">{{ model.description | markdown | safe }}</p>
  {% endif %}
  <p style="text-wrap: balance">{{ entry.description_summary | markdown | safe }}</p>
  {% if model.datasets.length > 1 %}
    <h3>Related Datasets</h3>
    <ul>
      {% for dataset in model.datasets %}
        {% if dataset.id != entry.id and dataset.status != "deprecated" %}
          <li>
            {% if dataset.status == 'live' or dataset.status == 'available' %}
              <a href="/catalog/{{ dataset.id | slugify }}">{{ dataset.title }}</a>
            {% else %}
              {{ dataset.title }} ({{ dataset.status }})
            {% endif %}
            - {{ dataset.description | safe }}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  {% endif %}
  <h2>Examples</h2>
  <table>
    {% for notebook in entry.notebooks %}
      <tr>
        <td style="text-align: center"><img src="/assets/github-mark.svg" height="18"/>
        </td>
        <td>
          <a href="{{ notebook.githubUrl }}">{{ notebook.title }} (Github)</a>
        </td>
      </tr>
      <tr>
        <td style="text-align: center;"><img src="/assets/colab.svg" height="18"/>
        </td>
        <td>
          <a href="{{ notebook.colabUrl }}">{{ notebook.title }} (Colab)</a>
        </td>
      </tr>
    {% endfor %}
  </table>
  {% for example in entry.examples %}
    <div class="frame">
      <div class="frameHeader">
        <div class="frameHeaderTitle">dynamical.org - {{ entry.title | truncate(30, true, '...') }}</div>
        <div class="frameHeaderSubtitle">{{ example.title }}</div>
      </div>
      {{ example.code | highlight('py', 'frameContent frameContentDesktop') | safe }}
    </div>
  {% endfor %}
  <h2>Dimensions</h2>
  <div class="table-container">
    <table class="data">
      <tr>
        <th/>
        <th class='right'>min</th>
        <th class='right'>max</th>
        <th class='right'>units</th>
      </tr>
      {% for dim in entry.dimensions %}
        <tr>
          <td>
            <strong>{{ dim.name }}</strong>
          </td>
          <td class='right'>{{ dim.statistics_approximate.min | roundIfNumber(3) }}</td>
          <td class='right'>{{ dim.statistics_approximate.max | roundIfNumber(3) if dim.statistics_approximate.max != null else "Present" }}</td>
          <td class='right'>{{ dim.units }}</td>
        </tr>
        <tr class="metadata-comment">
          <td colspan="4">
            <span></span>
          </td>
        </tr>
      {% endfor %}
    </table>
  </div>
  <h2>Variables</h2>
  {{ variableTable(entry.variables) }}
  {% for group in entry.variableGroups %}
    <details class="variable-group">
      <summary><strong>{{ group.name | replace("_", " ") | title }}</strong> ({{ group.variables.length }} variable{{ "s" if group.variables.length != 1 }})</summary>
      {{ variableTable(group.variables) }}
    </details>
  {% endfor %}
  <p class="metadata-comment">
    Don't see what you're looking for? Let us know at
    <a href="mailto:feedback@dynamical.org">feedback@dynamical.org</a>.
  </p>
  <h2>Details</h2>
    <h3>License</h3>
    {{ entry.license_md | markdown | safe }}

    <h3>Attribution and citation</h3>
    <p><i>{{ entry.attribution }}</i></p>
    <p>Or <i>{{ model.name }} from dynamical.org.</i></p>
    <p>
    <a href="https://doi.org/10.5281/zenodo.18777399"><img src="https://zenodo.org/badge/859043226.svg" alt="DOI"/></a>
    </p>
    {{ entry.description_details | markdown | safe }}
</div>