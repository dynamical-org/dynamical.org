---
layout: base.njk
pagination:
  data: catalog.entries
  alias: entry
  size: 1
  addAllPagesToCollections: true
permalink: 'catalog/{{entry.id | slugify}}/'
eleventyComputed:
  title: '{{entry.title}}'
  description: '{{ entry.description_meta }}'
  keywords: '{{ entry.model_name }}, {{ entry.title }}, {{ entry.model_name }} zarr, {{ entry.model_name }} data, {% if entry.forecast_domain %}weather forecast data{% else %}weather analysis data, reanalysis{% endif %}, cloud-optimized weather data, analysis-ready, Xarray, Icechunk'
  socialTitle: '{{ entry.title }} — dynamical.org'
  socialImage: '{{ entry.thumbnail }}'
  licenseName: '{{ entry.license_links[0].title }}'
  licenseUrl: '{{ entry.license_links[0].href }}'
---

<style>
  .content.catalog-item {
    font-size: 1.4rem;
  }
  .metadata-comment {
    font-size: 80%;
  }
  .metadata-comment td {
    padding-top: 0;
  }
  .metadata-comment span {
    background-color: rgb(250, 250, 250);
    color: rgb(45, 45, 45);
  }
  .variable-group {
    margin-top: 1rem;
  }
  .variable-group > summary {
    cursor: pointer;
    font-size: 1.1em;
  }
  .variable-group > summary > strong {
    margin-left: 0.5em;
  }

  /* Variables — dense table. Dimensions are stated once above (they're
     identical across a group's variables) rather than repeated per row. */
  .var-note,
  .var-dims-note {
    margin: 0 0 0.75rem;
    color: var(--muted-text);
    font-size: 1.25rem;
  }
  table.var-table {
    border-collapse: collapse;
    width: 100%;
    border: 1px solid var(--border-color);
  }
  .var-table th,
  .var-table td {
    text-align: left;
    padding: 0.5rem 1rem;
    vertical-align: baseline;
  }
  .var-table th {
    border-bottom: 1px solid var(--border-color);
  }
  .var-table tr:not(:last-child) td {
    border-bottom: 1px dotted var(--border-muted-color);
  }
  .var-table .var-units {
    text-align: right;
    white-space: nowrap;
    color: var(--muted-text);
  }
  .var-name {
    font-weight: 700;
    display: block;
  }
  .var-long {
    display: block;
  }
  .var-src {
    color: var(--muted-text);
  }
  .var-desc {
    display: block;
    margin-top: 0.15rem;
    color: var(--muted-text);
    font-size: 1.25rem;
  }
  /* The unsharded chunk table has only two columns, so let it shrink to its
     content rather than stretching to the shared .data min-width. Sharded
     chunk tables (three columns) keep the wider default. */
  .detail-prose table.data:has(thead th:nth-child(2):last-child) {
    min-width: 0;
  }
</style>
<script type="application/ld+json">{{ entry.jsonld | dump | safe }}</script>
{% macro variableTable(variables, groupName) %}
  {%- set commonDims = variables[0].dimension_names | join(' × ') -%}
  {% if groupName %}
    <p class="var-note">These variables live in the <code>{{ groupName }}</code> Zarr group (e.g. pass <code>group="{{ groupName }}"</code> to <code>dynamical_catalog.open()</code> or <code>xr.open_zarr()</code>).</p>
  {% endif %}
  <p class="var-dims-note">Dimensions: <code>{{ commonDims }}</code></p>
  <div class="table-container">
    <table class="var-table">
      <tr>
        <th>variable</th>
        <th class="var-units">units</th>
      </tr>
      {% for variable in variables %}
        {%- set varDims = variable.dimension_names | join(' × ') -%}
        <tr>
          <td>
            <span class="var-name">{{ variable.name }}</span>
            <span class="var-long">{{ variable.long_name }}{% if variable.short_name %} (<code class="var-src" title="Source (GRIB) short name, reference only, not an access key">{{ variable.short_name }}</code>){% endif %}</span>
            {%- if variable.comment or varDims != commonDims %}<span class="var-desc">{{ variable.comment }}{% if variable.comment and varDims != commonDims %} · {% endif %}{% if varDims != commonDims %}dimensions: {{ varDims }}{% endif %}</span>{% endif %}
          </td>
          <td class="var-units">{{ variable.units }}</td>
        </tr>
      {% endfor %}
    </table>
  </div>
{% endmacro %}
<div class="content catalog-item">
  {%- set model = catalog.models | find('id', entry.model_id) %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dynamical.org/" },
      { "@type": "ListItem", "position": 2, "name": "Catalog", "item": "https://dynamical.org/catalog/" },
      {% if model %}{ "@type": "ListItem", "position": 3, "name": {{ model.name | dump | safe }}, "item": "https://dynamical.org/catalog/models/{{ model.id | slugify }}/" },
      { "@type": "ListItem", "position": 4, "name": {{ entry.title | dump | safe }}, "item": "https://dynamical.org{{ page.url }}" }{% else %}{ "@type": "ListItem", "position": 3, "name": {{ entry.title | dump | safe }}, "item": "https://dynamical.org{{ page.url }}" }{% endif %}
    ]
  }
  </script>
  <div>
    <a href="/catalog">Catalog</a>
    {% if model %}&gt; <a href="/catalog/models/{{ model.id | slugify }}/">{{ model.name }}</a>{% endif %}
    &gt; {{ entry.title }}
  </div>
  <div style="margin: 3rem 0;">
    {% include "catalog-entry-status.njk" %}
    <h1>{{ entry.title }}</h1>
  </div>
  <table>
    <tr>
      <td>Spatial domain</td>
      <td>{{ entry.spatial_domain }}</td>
    </tr>
    <tr>
      <td>Spatial resolution</td>
      <td>{{ entry.spatial_resolution }}</td>
    </tr>
    <tr>
      <td>Time domain</td>
      <td>{{ entry.time_domain }}</td>
    </tr>
    <tr>
      <td>Time resolution</td>
      <td>{{ entry.time_resolution }}</td>
    </tr>
    {% if entry.forecast_domain %}
      <tr>
        <td>Forecast domain</td>
        <td>{{ entry.forecast_domain }}</td>
      </tr>
      <tr>
        <td>Forecast resolution</td>
        <td>{{ entry.forecast_resolution }}</td>
      </tr>
    {% endif %}
  </table>
  <p>
    <span><a href="https://stac.dynamical.org/{{ entry.id }}/collection.json">STAC</a> (<a href="https://radiantearth.github.io/stac-browser/#/external/stac.dynamical.org/{{ entry.id }}/collection.json">browse</a>)</span>
    {%- set validationReport = validationReports.entries | find('datasetId', entry.id) %}
    {% if validationReport %}
      · <a href="/catalog/{{ entry.id }}/validation/">validation report</a>
    {% elif entry.validation_report_href %}
      · <a href="{{ entry.validation_report_href }}">validation report</a>
    {% endif %}
  </p>
  {% if model.description %}
    <p style="text-wrap: balance">{{ model.description | markdown | safe }}</p>
  {% endif %}
  <p style="text-wrap: balance">{{ entry.description_summary | markdown | safe }}</p>
  {% if model.datasets.length > 1 %}
    <h3>Related Datasets</h3>
    <ul>
      {% for dataset in model.datasets %}
        {% if dataset.id != entry.id and dataset.status != "deprecated" %}
          <li>
            {% if dataset.status == 'live' or dataset.status == 'available' %}
              <a href="/catalog/{{ dataset.id | slugify }}">{{ dataset.title }}</a>
            {% else %}
              {{ dataset.title }} ({{ dataset.status }})
            {% endif %}
            - {{ dataset.description | safe }}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  {% endif %}
  <h2>Examples</h2>
  <table>
    {% for notebook in entry.notebooks %}
      <tr>
        <td style="text-align: center"><img src="/assets/github-mark.svg" height="18"/>
        </td>
        <td>
          <a href="{{ notebook.githubUrl }}">{{ notebook.title }} (Github)</a>
        </td>
      </tr>
      <tr>
        <td style="text-align: center;"><img src="/assets/colab.svg" height="18"/>
        </td>
        <td>
          <a href="{{ notebook.colabUrl }}">{{ notebook.title }} (Colab)</a>
        </td>
      </tr>
    {% endfor %}
  </table>
  {% for example in entry.examples %}
    <div class="frame">
      <div class="frameHeader">
        <div class="frameHeaderTitle">dynamical.org - {{ entry.title | truncate(30, true, '...') }}</div>
        <div class="frameHeaderSubtitle">{{ example.title }}</div>
      </div>
      {{ example.code | highlight('py', 'frameContent frameContentDesktop') | safe }}
    </div>
  {% endfor %}
  <h2>Dimensions</h2>
  <div class="table-container">
    <table class="data">
      <tr>
        <th/>
        <th class='right'>min</th>
        <th class='right'>max</th>
        <th class='right'>units</th>
      </tr>
      {% for dim in entry.dimensions %}
        <tr>
          <td>
            <strong>{{ dim.name }}</strong>
          </td>
          <td class='right'>{{ dim.statistics_approximate.min | roundIfNumber(3) }}</td>
          <td class='right'>{{ dim.statistics_approximate.max | roundIfNumber(3) if dim.statistics_approximate.max != null else "Present" }}</td>
          <td class='right'>{{ dim.units }}</td>
        </tr>
        <tr class="metadata-comment">
          <td colspan="4">
            <span></span>
          </td>
        </tr>
      {% endfor %}
    </table>
  </div>
  <h2>Variables</h2>
  <p class="var-note">Access a variable by its name (the bold identifier, e.g. <code>ds["{{ entry.variables[0].name }}"]</code>).</p>
  {{ variableTable(entry.variables) }}
  {% for group in entry.variableGroups %}
    <details class="variable-group">
      <summary><strong>{{ group.name | replace("_", " ") | title }}</strong> ({{ group.variables.length }} variable{{ "s" if group.variables.length != 1 }})</summary>
      {{ variableTable(group.variables, group.name) }}
    </details>
  {% endfor %}
  <p class="metadata-comment">
    Don't see what you're looking for? Let us know at
    <a href="mailto:feedback@dynamical.org">feedback@dynamical.org</a>.
  </p>
  <h2>Details</h2>
    <h3>License</h3>
    {{ entry.license_md | markdown | safe }}

    <h3>Attribution and citation</h3>
    <p><i>{{ entry.attribution }}</i></p>
    <p>Or <i>{{ model.name }} from dynamical.org.</i></p>
    <p>
    <a href="https://doi.org/10.5281/zenodo.18777399"><img src="https://zenodo.org/badge/859043226.svg" alt="DOI"/></a>
    </p>
    <div class="detail-prose">{{ entry.description_details | markdown | safe }}</div>
</div>