---
layout: base.njk
title: variable table density preview
permalink: /variable-preview/
---

<style>
  .dims-note {
    margin: 0.5rem 0 1.5rem;
    color: var(--muted-text);
    font-size: 1.25rem;
  }

  /* Option A — list (catalog style) */
  .var-list {
    list-style: none;
    padding-inline-start: 0;
  }
  .var-list li {
    padding: 0.6rem 0;
  }
  .var-list li:not(:last-of-type) {
    border-bottom: 1px dotted var(--border-muted-color);
  }
  .var-head {
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
  }
  .var-head .u {
    margin-left: auto;
    color: var(--muted-text);
    font-variant-numeric: tabular-nums;
  }
  .var-desc {
    color: var(--muted-text);
    font-size: 1.25rem;
  }

  /* Option B — dense table */
  table.var-table {
    border-collapse: collapse;
    width: 100%;
    border: 1px solid var(--border-color);
  }
  .var-table th,
  .var-table td {
    text-align: left;
    padding: 0.5rem 1rem;
    vertical-align: baseline;
  }
  .var-table tr:not(:last-child) td {
    border-bottom: 1px dotted var(--border-muted-color);
  }
  .var-table .u {
    text-align: right;
    white-space: nowrap;
    color: var(--muted-text);
  }
  .var-table .var-desc {
    display: block;
  }
</style>

<div class="content">
  {%- set entry = catalog.entries | find('id', 'noaa-hrrr-forecast-48-hour') -%}
  {%- set dims = entry.variables[0].dimension_names | join(' × ') -%}

  <h1>Variable table density</h1>
  <p>{{ entry.title }} — {{ entry.variables.length }} variables. The dimensions are identical
  for every variable, so they're stated once instead of repeated per row (that repeated,
  no-wrap column is what forced the horizontal overflow today).</p>

  <h2>Option A — list</h2>
  <p class="dims-note">Dimensions (all variables): <strong>{{ dims }}</strong></p>
  <ul class="var-list">
    {% for v in entry.variables %}
      <li>
        <div class="var-head">
          <span>{{ v.name }}{% if v.short_name %} <code>{{ v.short_name }}</code>{% endif %}</span>
          <span class="u">{{ v.units }}</span>
        </div>
        <div class="var-desc">{{ v.long_name }}{% if v.comment %} — {{ v.comment }}{% endif %}</div>
      </li>
    {% endfor %}
  </ul>

  <h2 style="margin-top: 5rem;">Option B — dense table</h2>
  <p class="dims-note">Dimensions (all variables): <strong>{{ dims }}</strong></p>
  <div class="table-container">
    <table class="var-table">
      <tr><th>variable</th><th class="u">units</th></tr>
      {% for v in entry.variables %}
        <tr>
          <td>{{ v.name }}{% if v.short_name %} <code>{{ v.short_name }}</code>{% endif %}<span class="var-desc">{{ v.long_name }}{% if v.comment %} — {{ v.comment }}{% endif %}</span></td>
          <td class="u">{{ v.units }}</td>
        </tr>
      {% endfor %}
    </table>
  </div>

  <h2 style="margin-top: 5rem;">Current (baseline)</h2>
  <div class="table-container">
    <table class="data">
      <tr>
        <th/>
        <th class="right">units</th>
        <th class="right" style="white-space: nowrap;">dimensions</th>
      </tr>
      {% for v in entry.variables %}
        <tr>
          <td>
            <strong>{{ v.name }}</strong>{% if v.short_name %} (<code>{{ v.short_name }}</code>){% endif %}
            <p style="font-size: 80%;">{{ v.long_name }}</p>
            {% if v.comment %}<p style="font-size: 80%;">{{ v.comment }}</p>{% endif %}
          </td>
          <td class="right">{{ v.units }}</td>
          <td class="right" style="white-space: nowrap;">{{ v.dimension_names | join(' × ') }}</td>
        </tr>
      {% endfor %}
    </table>
  </div>
</div>
