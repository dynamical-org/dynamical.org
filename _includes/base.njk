<!DOCTYPE html>
<html lang="{{ metadata.language }}">
  <head>
    <meta charset="utf-8"/>
    <meta name="Content-Type" content="text/html; charset=UTF-8"/>
    <meta name="author" content="Dynamical Team"/>
    <meta name="keywords" content="{{ keywords or 'cloud-optimized weather data, analysis-ready weather data, weather and climate data, weather data catalog, Zarr, Icechunk, Xarray, NOAA GFS, ECMWF IFS, HRRR' }}"/>
    <title>dynamical.org {{ '- ' + title if title else '' }}</title>
    <meta name="description" content="{{ description or metadata.description }}"/>
    {% if licenseName and licenseUrl %}<meta name="license" content="name={{ licenseName }}, url={{ licenseUrl }}"/>
    {% else %}<meta name="license" content="name=BY-NC-SA(4.0), url=https://creativecommons.org/licenses/by-nc-sa/4.0/"/>
    {% endif %}
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <link rel="canonical" href="https://dynamical.org{{ page.url }}"/>
    {% set isPodcast = tags and ("podcast" in tags) %}
    {% set isArticle = tags and (("podcast" in tags) or ("updates" in tags) or ("research" in tags)) %}
    {# Titled pages get a unique social card; pages without a title (e.g. the many
       auto-generated scorecard pages) share one default brand card. #}
    {% set ogCardSlug = (page.url | ogSlug) if (socialTitle or title) else "default" %}
    {% set isGeneratedOgImage = not socialImage and not isPodcast %}
    {% set ogImage = socialImage or ("https://dynamical.org/assets/weathering/weathering_logo_figs.png" if isPodcast else ("https://dynamical.org/assets/og/" + ogCardSlug + ".png")) %}
    {% set ogTitle = socialTitle or (("weathering podcast - episode " + episode_number + ": " + title) if isPodcast else (title or metadata.title)) %}
    {% set ogDescription = description or metadata.description %}
    {% set ogImageAlt = socialImageAlt or ogTitle %}
    <meta property="og:type" content="{{ "article" if isArticle else "website" }}"/>
    <meta property="og:title" content="{{ ogTitle }}"/>
    <meta property="og:description" content="{{ ogDescription }}"/>
    <meta property="og:url" content="https://dynamical.org{{ page.url }}"/>
    <meta property="og:site_name" content="dynamical.org"/>
    <meta property="og:image" content="{{ ogImage }}"/>
    <meta property="og:image:alt" content="{{ ogImageAlt }}"/>
    {% if isGeneratedOgImage %}<meta property="og:image:type" content="image/png"/>
    <meta property="og:image:width" content="1200"/>
    <meta property="og:image:height" content="630"/>
    {% endif %}
    {% if isPodcast and audio_url %}<meta property="og:audio" content="{{ audio_url }}"/>
    <meta property="og:audio:type" content="audio/mpeg"/>
    {% endif %}<meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="{{ ogTitle }}"/>
    <meta name="twitter:description" content="{{ ogDescription }}"/>
    <meta name="twitter:image" content="{{ ogImage }}"/>
    <meta name="twitter:image:alt" content="{{ ogImageAlt }}"/>
    <link rel="stylesheet" type="text/css" href="/main.css?v={{ assets.mainCss }}"/>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&display=swap" rel="stylesheet"/>
    <link href="/prism-atom-dark.css" rel="stylesheet"/>
    <link rel="icon" href="https://assets.dynamical.org/identity/logo/favicon/favicon.svg" type="image/svg+xml"/>
    <link rel="alternate icon" href="https://assets.dynamical.org/identity/logo/favicon/favicon.ico"/>
    <link rel="apple-touch-icon" href="https://assets.dynamical.org/identity/logo/favicon/apple-touch-icon.png"/>
    <link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}"/>
    <link rel="alternate" href="/feed/feed.json" type="application/json" title="{{ metadata.title }}"/>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://dynamical.org/#organization",
          "name": "dynamical.org",
          "url": "https://dynamical.org/",
          "description": {{ metadata.description | dump | safe }},
          "logo": "https://assets.dynamical.org/identity/logo/lockup/lockup-black.svg",
          "email": "{{ metadata.author.email }}",
          "sameAs": [
            "https://github.com/dynamical-org",
            "https://www.linkedin.com/company/dynamical-org",
            "https://youtube.com/@dynamical-org"
          ]
        },
        {
          "@type": "WebSite",
          "@id": "https://dynamical.org/#website",
          "url": "https://dynamical.org/",
          "name": {{ metadata.title | dump | safe }},
          "description": {{ metadata.description | dump | safe }},
          "publisher": { "@id": "https://dynamical.org/#organization" }
        }
      ]
    }
    </script>
    {% if metadata.betterstackErrorsToken %}<!-- BetterStack Errors: browser error tracking + pageview telemetry -->
    <script>
      !function(b,e,t,r){
        b[t]=b[t]||function(...args){(b[t].q=b[t].q||[]).push(args)};
        b[t].l=+new Date;
        var s=e.createElement('script'); s.async=1; s.crossOrigin='anonymous';
        s.src='https://betterstack.net/b.js?t='+r;
        (e.head||e.getElementsByTagName('head')[0]).appendChild(s);
      }(window,document,'betterstack','{{ metadata.betterstackErrorsToken }}');
      // Only report from the production host; keeps local dev and *.pages.dev previews out of the dashboard.
      if (location.hostname === 'dynamical.org') {
        betterstack('init', { environment: 'production' });
      }
    </script>{% endif %}
  </head>
  <body>
    <nav aria-label="Primary">
      <ul>
        <li><a href="/" class="nav-lockup"><picture><source srcset="https://assets.dynamical.org/identity/logo/lockup/lockup-white.svg" media="(prefers-color-scheme: dark)"><img src="https://assets.dynamical.org/identity/logo/lockup/lockup-black.svg" alt="dynamical.org" height="30"></picture></a></li>
        <li><a href="/catalog">catalog</a></li>
        <li><a href="/#research">research</a></li>
        <li><a href="/updates">updates</a></li>
        <li><a href="/about">about</a></li>
        <li><a href="/podcast">podcast</a></li>
        <li><a href="https://status.dynamical.org">status</a></li>
      </ul>
    </nav>
    {{ content | safe }}

    <footer role="contentinfo">
      <div class="footer-grid">
        <div class="footer-col">
          <h2>Explore</h2>
          <ul>
            <li><a href="/#research">Research</a></li>
            <li><a href="/updates">Updates</a></li>
            <li><a href="/catalog">Catalog</a></li>
            <li><a href="/podcast">Podcast</a></li>
            <li><a href="https://status.dynamical.org">Status</a></li>
            <li><a href="/about">About</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h2>Connect</h2>
          <ul>
            <li><a href="https://github.com/dynamical-org">GitHub</a></li>
            <li><a href="https://www.linkedin.com/company/dynamical-org">LinkedIn</a></li>
            <li><a href="https://youtube.com/@dynamical-org">YouTube</a></li>
            <li><a href="/feed/feed.xml">Atom</a> · <a href="/feed/feed.json">JSON</a></li>
            <li><a href="mailto:feedback@dynamical.org">feedback@dynamical.org</a></li>
          </ul>
        </div>
        <div class="footer-col footer-dispatch">
          <h2>Dispatch</h2>
          <p>New datasets, validation findings, and lab notes — a few times a month.
          <form
            action="https://buttondown.email/api/emails/embed-subscribe/dynamical"
            method="post"
            target="popupwindow"
            onsubmit="window.open('https://buttondown.email/dynamical', 'popupwindow')"
            class="footer-subscribe"
          >
            <label class="visually-hidden" for="footer-email">Email</label>
            <input type="email" id="footer-email" name="email" placeholder="marshall@dynamical.org"/>
            <input type="hidden" value="1" name="embed"/>
            <input type="submit" value="Subscribe"/>
          </form>
          <p class="footer-archive"><a href="/updates">Browse the archive →</a></p>
        </div>
      </div>
      <div class="footer-base">
        <span><a href="/license/">License</a> · <a href="/privacy/">Privacy</a></span>
        <span>Built {% currentBuildDate %}</span>
      </div>
    </footer>

    <!-- Latest content popup -->
    {% set latestUpdate = collections.updates | reverse | first %}
    {% set latestPodcast = collections.podcast | reverse | first %}

    {# Pick the most recent across updates and podcast. Lab notes (research) are
       intentionally excluded from the popup. #}
    {% set latestContent = null %}
    {% set contentType = "" %}
    {% set contentIcon = "" %}
    {% set contentUrl = "" %}
    {% if latestUpdate %}
      {% set latestContent = latestUpdate %}
      {% set contentType = "Latest update" %}
      {% set contentIcon = "📰" %}
      {% set contentUrl = latestUpdate.url %}
    {% endif %}
    {% if latestPodcast and (not latestContent or latestPodcast.date > latestContent.date) %}
      {% set latestContent = latestPodcast %}
      {% set contentType = "New podcast episode" %}
      {% set contentIcon = "🎙️" %}
      {% set contentUrl = latestPodcast.url %}
    {% endif %}
    {% if latestContent %}
      <div id="latest-popup">
        <div class="popup-header">
          <span class="popup-type">{{ contentIcon }} {{ contentType }}</span>
          <button id="latest-close" class="popup-close">
            &times;
          </button>
        </div>
        <a href="{{ contentUrl }}" class="popup-title">{{ latestContent.data.title }}</a>
        <div class="popup-date">{{ latestContent.date | readableDate }}</div>
        <script>
          (function () {
            const popup = document.getElementById('latest-popup');
            const latestDate = "{{ latestContent.date | isoDate }}";
            const seenDate = localStorage.getItem('latestPopupDate');
            // if we've already seen this or something newer, hide the popup immediately
            if (seenDate && seenDate >= latestDate) {
              popup.style.display = 'none';
              return;
            }
            // record that we've seen this date, then hide the popup
            const dismiss = () => {
              localStorage.setItem('latestPopupDate', latestDate);
              popup.style.display = 'none';
            };
            document.getElementById('latest-close').addEventListener('click', dismiss);
            // clicking through to the post also dismisses it (navigation follows)
            popup.querySelector('.popup-title').addEventListener('click', dismiss);
          })();
        </script>
      </div>
    {% endif %}
  </body>
</html>
