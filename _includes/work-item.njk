{# Renders one "work" entry in a .work-list (project or note). The wrapper,
   title, and the "{type} →" tag (top-right, positioned absolutely so the blurb
   spans full width) are shared. Projects supply their blurb (and any code) as
   their .njk body; notes use their `summary` frontmatter and get a date prefix.
     item — an Eleventy collection item (collections.projects / .research) #}
{% macro workItem(item) %}
{%- set isProject = item.data.type == "Project" %}
{%- set meta = item.data.type or "Note" %}
{%- if not isProject %}
{%-   set year = item.data.year or (item.date | readableDate("yyyy")) %}
{%-   if year %}{% set meta = year ~ " · " ~ meta %}{% endif %}
{%- endif %}
<a class="work-item" href="{{ item.data.url if isProject else item.url }}">
  <div class="work-main">
    <h3>{{ item.data.title }}</h3>
    {%- if isProject %}{{ item.templateContent | safe }}{% elif item.data.summary %}<p>{{ item.data.summary }}</p>{% endif %}
  </div>
  <span style="position: absolute; top: 2rem; right: 0; font-size: 1.2rem; color: var(--muted-text); white-space: nowrap;">{{ meta }} →</span>
</a>
{% endmacro %}
