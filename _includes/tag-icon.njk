} -%}
{%- if paths[name] -%}
<svg viewBox="0 0 24 24" width="1em" height="1em" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-0.18em"{% if title %} role="img" aria-label="{{ title }}"><title>{{ title }}</title>{% else %} aria-hidden="true">{% endif %}{{ paths[name] | safe }}</svg>
{%- endif -%}
{%- endmacro -%}
